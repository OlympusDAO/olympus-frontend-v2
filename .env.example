# Required: WalletConnect Cloud project ID (https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: Google Analytics 4 measurement ID
VITE_GA_MEASUREMENT_ID=

# Optional: PostHog analytics
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# On Vercel set this to /panoptes (uses rewrite proxy); locally keep same as HOST
VITE_PUBLIC_POSTHOG_INGEST_HOST=https://us.i.posthog.com

# Optional: Enable testnet mode (Sepolia)
VITE_TESTNET_MODE=

# Optional: Override the mainnet RPC URL (e.g. http://localhost:8545 for a local anvil fork).
# Used for fork testing of the OHM v1 migration. Defaults to a public node.
VITE_MAINNET_RPC_URL=

# Optional: Base URL for OHM v1 migration merkle claim shards (Vercel Blob / CDN).
# Production shards are produced + uploaded from the ohm-v1-balances repo
# (`pnpm merkle shard --upload`). If unset, the app falls back to `${BASE_URL}migration`
# (files in public/migration, written locally for testing by `pnpm test:tree`).
VITE_MIGRATION_CLAIMS_BASE_URL=

# Required: The Graph Gateway API key (https://thegraph.com/studio)
VITE_THEGRAPH_API_KEY=

# Optional: Treasury subgraph metrics API. If omitted, the treasury client uses its default endpoint.
VITE_TREASURY_SUBGRAPH_METRICS_API=

# Required: Olympus Units API base URL for runtime requests
VITE_OLYMPUS_UNITS_API_ENDPOINT=

# Optional: OpenAPI spec URL for codegen (pnpm codegen), defaults to dev endpoint
OLYMPUS_API_URL=

# Required: Safe Transaction Service API key for submitting multisig transactions
VITE_OLYMPUS_SAFE_API_KEY=

# PostHog CLI — for sourcemap upload in CI (personal API key with "error tracking write" scope)
# Run: pnpm build && pnpm sourcemap:upload
POSTHOG_CLI_PROJECT_ID=
POSTHOG_CLI_API_KEY=
