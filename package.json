{
  "name": "olympus-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm codegen && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome lint --write src/",
    "lint:check": "biome lint src/",
    "lint:fix": "pnpm run lint",
    "format": "biome format --write src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "prepare": "husky",
    "codegen": "orval",
    "test": "vitest run",
    "test:watch": "vitest",
    "shard:migration": "node scripts/shard-merkle-tree.ts",
    "test:tree": "node scripts/make-test-tree.ts",
    "fork:setup": "node scripts/fork-setup.ts",
    "sourcemap:upload": "posthog-cli sourcemap inject --directory ./dist/assets && posthog-cli sourcemap upload --directory ./dist/assets"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@number-flow/react": "^0.5.14",
    "@olympusdao/treasury-subgraph-client": "^3.0.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@remixicon/react": "^4.6.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@wagmi/core": "^2.22.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dnum": "^2.17.0",
    "driver.js": "^1.4.0",
    "graphql": "^16.13.0",
    "graphql-request": "^7.4.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.525.0",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.365.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-ga4": "^2.1.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "viem": "^2.46.3",
    "wagmi": "^2.19.5",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@posthog/cli": "^0.7.11",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vercel/blob": "^2.4.0",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.3.1",
    "orval": "^8.5.3",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-webfont-dl": "^3.12.0",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
